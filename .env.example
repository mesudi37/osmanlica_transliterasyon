# Copy to .env and adjust before starting the server.

# Path to your manual lookup TSV (Turkish word → Ottoman form)
LOOKUP_FILE=manual_lookup.tsv

# Path to abbreviation lookup TSV
ABBREV_FILE=abbrev_lookup.tsv

# Use historical Ottoman orthographic overrides (true/false)
HISTORICAL_ORTHOGRAPHY=true

# Comma-separated allowed CORS origins, or * for all
CORS_ORIGINS=*

# Set this if your data files live elsewhere (e.g. /data/ottoman)
# OTTOMAN_BASE_DIR=/data/ottoman
